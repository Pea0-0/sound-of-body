# Python runtime (~50 MB of DLLs, PYDs, and bundled packages).
# Run from source instead: python heartbeat.py
dist/

# ── Runtime-generated output ──────────────────────────────────────────────────
music/data/
music/output/
music/output_*/
music/tharm_*/
