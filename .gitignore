# ── Environment ───────────────────────────────────────────────────────────────
.env

# ── IDE (machine-specific; configure locally) ─────────────────────────────────
.vscode/settings.json
pyrightconfig.json

# ── Docs (content is in README.md) ────────────────────────────────────────────
docs/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── PyInstaller Windows build (dist/) ─────────────────────────────────────────
